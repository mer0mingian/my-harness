,"type":"geo","props":{"w":95.68924483073539,"h":96.17457273923378,"geo":"ellipse","dash":"dotted","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"semi","size":"m","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Arch"}]}]}},"parentId":"page:page","index":"b0RA8UIzt","typeName":"shape"},{"x":1631.8527319425248,"y":58.12498169466227,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:7GF8KTOJJodjx2xnjEWmu","type":"geo","props":{"w":898.5009751838179,"h":844.2794821664168,"geo":"rectangle","dash":"dotted","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","content":[{"type":"paragraph"}]}},"parentId":"page:page","index":"b0lZWIDxV","typeName":"shape"},{"x":2048.0570562160938,"y":548.5990377312546,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:aMSlTRtfQ6ZyHl89rSTWb","type":"text","props":{"color":"black","size":"m","w":244.94278220773163,"font":"draw","textAlign":"middle","autoSize":false,"scale":1,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Divide & Conquer"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Spikey time"}]}]}},"parentId":"page:page","index":"b0JGnfSHV","typeName":"shape"},{"meta":{},"id":"binding:yq1Gq0HU4nMWYzOt-INVy","type":"arrow","fromId":"shape:vAAli32fcVYZks6LyFYHv","toId":"shape:dbVtvaE2w60wkuoHRebxt","props":{"isPrecise":true,"isExact":false,"normalizedAnchor":{"x":0.5,"y":0.4999999999999995},"snap":"center","terminal":"start"},"typeName":"binding"},{"meta":{},"id":"binding:wjNAUhP8vrCAEUKWp_8ku","type":"arrow","fromId":"shape:vAAli32fcVYZks6LyFYHv","toId":"shape:C7kp6l3maS11CI4d8HcD8","props":{"isPrecise":true,"isExact":false,"normalizedAnchor":{"x":0.5,"y":0.5},"snap":"center","terminal":"end"},"typeName":"binding"},{"x":6246.911428279282,"y":1917.685138226758,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:vAAli32fcVYZks6LyFYHv","type":"arrow","props":{"kind":"elbow","elbowMidPoint":0.5,"dash":"draw","size":"m","fill":"none","color":"black","labelColor":"black","bend":0,"start":{"x":0,"y":0},"end":{"x":2,"y":0},"arrowheadStart":"bar","arrowheadEnd":"arrow","richText":{"type":"doc","content":[{"type":"paragraph"}]},"labelPosition":0.5,"font":"draw","scale":1},"parentId":"page:page","index":"b1r0uFqeV","typeName":"shape"},{"x":6690.487857200237,"y":1824.4984278586194,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:C7kp6l3maS11CI4d8HcD8","type":"geo","props":{"w":461.84643496095487,"h":201.98306517485798,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"m","font":"draw","align":"middle","verticalAlign":"middle","richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"PR"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Archive PRD"}]}]}},"parentId":"page:page","index":"b1qW5kreV","typeName":"shape"},{"meta":{},"id":"page:4HXlX8UVh4_VSuHOODuqS","name":"Quality Criteria","index":"a2ImRyBV","typeName":"page"},{"x":63.79998779296875,"y":40,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:AKLM6PdNkIMU1rNPELMSQ","type":"text","props":{"color":"black","size":"m","w":1870.0383584700983,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Um tiefe, hochgradig testbare Einheiten zu beschreiben und gleichzeitig vertikale Schnitte durch ein System zu legen, ist die Kombination aus "},{"type":"text","marks":[{"type":"bold"}],"text":"Domain-Driven Design (DDD)"},{"type":"text","text":" und der "},{"type":"text","marks":[{"type":"bold"}],"text":"Hexagonalen Architektur"},{"type":"text","text":" (auch bekannt als "},{"type":"text","marks":[{"type":"italic"}],"text":"Ports and Adapters"},{"type":"text","text":") der maßgebliche theoretische Unterbau."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Diese Prinzipien haben das agile Engineering geprägt, da sie die fachliche Logik von technischer Komplexität entkoppeln – eine Eigenschaft, die für die Integration von probabilistischen KI-Workflows in deterministische Softwaresysteme essentiell ist."}]},{"type":"heading","attrs":{"dir":"auto","level":2},"content":[{"type":"text","text":"1. Kernkonzepte für tiefe Einheiten und vertikale Slices"}]},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Domain-Driven Design (DDD): Die fachliche Tiefe"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"DDD nach Eric Evans bietet das Vokabular, um \"tiefe Einheiten\" zu definieren, die unabhängig von Infrastruktur (wie Datenbanken oder LLM-APIs) funktionieren:"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Bounded Contexts:"},{"type":"text","text":" Definieren die Grenzen eines vertikalen Slices. Ein Slice sollte idealerweise innerhalb eines Kontexts verlaufen, um Kohäsion zu garantieren."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Aggregates:"},{"type":"text","text":" Dies sind die \"tiefen Einheiten\". Ein Aggregate ist ein Cluster von Domänenobjekten, die als eine Einheit für Datenänderungen betrachtet werden. Sie kapseln die Geschäftslogik und gewährleisten Invarianten, was sie zum perfekten Ziel für Unit-Tests macht."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ubiquitous Language:"},{"type":"text","text":" Die Verwendung einer gemeinsamen Sprache zwischen Entwicklern und Fachexperten, was bei der Prompt-Entwicklung für Agenten entscheidend ist."}]}]}]},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Hexagonale Architektur: Die Testbarkeit"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Die von Alistair Cockburn eingeführte Architektur ermöglicht es, die Domänenlogik (den Kern) von der Außenwelt zu isolieren."}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ports:"},{"type":"text","text":" Interfaces, die definieren, was die Anwendung benötigt (z. B. eine Datenquelle oder ein KI-Modell)."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Adapters:"},{"type":"text","text":" Implementierungen dieser Interfaces (z. B. ein "},{"type":"text","marks":[{"type":"code"}],"text":"OpenAIAdapter"},{"type":"text","text":" oder ein "},{"type":"text","marks":[{"type":"code"}],"text":"MockLLMAdapter"},{"type":"text","text":")."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Vorteil:"},{"type":"text","text":" Man kann den Kern testen, ohne eine echte API-Verbindung aufzubauen. Für KI-Workflows bedeutet dies, dass die Entscheidungskette eines Agenten unabhängig von den tatsächlichen (und oft teuren/langsamen) Modell-Aufrufen validiert werden kann."}]}]}]},{"type":"heading","attrs":{"dir":"auto","level":2},"content":[{"type":"text","text":"2. Evolutionäre Prinzipien des Agilen Engineerings"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Diese drei Prinzipien bilden das Rückgrat moderner Implementierungsstrategien:"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"PrinzipBeschreibungRelevanz für AI WorkflowsSOLID (speziell ISP & DIP)"},{"type":"text","text":"Interface Segregation und Dependency Inversion sorgen für lose Kopplung.Ermöglicht den fliegenden Wechsel zwischen verschiedenen LLMs oder lokalen Modellen."},{"type":"text","marks":[{"type":"bold"}],"text":"Test-Driven Development (TDD)"},{"type":"text","text":"Tests werden vor dem Code geschrieben.Bei KI schwierig (da Output stochastisch), führt aber zu "},{"type":"text","marks":[{"type":"bold"}],"text":"Evals"},{"type":"text","text":": Systematische Evaluation von Modell-Outputs gegen Gold-Standards."},{"type":"text","marks":[{"type":"bold"}],"text":"Micro-Kernels / Plugins"},{"type":"text","text":"Ein minimaler Kern wird durch spezialisierte Module erweitert.Ideal für agentische Systeme, bei denen ein \"Orchestrator\" verschiedene spezialisierte Agenten-Tools lädt."}]},{"type":"heading","attrs":{"dir":"auto","level":2},"content":[{"type":"text","text":"3. Anwendung auf AI Workflows & Agentische Systeme"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Um diese Prinzipien auf KI-Systeme zu übertragen, empfiehlt sich ein Übergang von klassischen \"Klassen\" zu "},{"type":"text","marks":[{"type":"bold"}],"text":"Funktionalen Ketten"},{"type":"text","text":" oder "},{"type":"text","marks":[{"type":"bold"}],"text":"Graphen"},{"type":"text","text":":"}]},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Vertikale Slices als \"Chain of Thought\""}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Ein vertikaler Slice in einem KI-Produkt umfasst oft:"}]},{"type":"orderedList","attrs":{"dir":"auto","start":1,"type":null},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Ingestion:"},{"type":"text","text":" Aufnahme des User-Inputs."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Reasoning:"},{"type":"text","text":" Der agentische Kern (Domain Logic), der entscheidet, welche Tools genutzt werden."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Action:"},{"type":"text","text":" Ausführung (Infrastructure)."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Indem man diesen Slice eng definiert, kann man eine spezifische Fähigkeit (z. B. \"Rechnungsanalyse\") isoliert optimieren und testen."}]}]}]},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Testbarkeit durch \"Deep Units\""}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"In agentischen Systemen sollte die "},{"type":"text","marks":[{"type":"bold"}],"text":"Logik der Aufgabenzerlegung"},{"type":"text","text":" (Planning) eine \"tiefe Einheit\" sein."}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"bold"}],"text":"Mathematischer Ansatz:"},{"type":"text","text":" Betrachten Sie den Agenten-Workflow als eine Zustandsmaschine. Die Transitionen zwischen Zuständen sollten rein logisch und deterministisch sein (testbar), während die LLM-Entscheidung als injizierter Adapter fungiert."}]}]}]},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Empfohlene Literatur & Ressourcen"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"italic"}],"text":"Clean Architecture"},{"type":"text","text":" von Robert C. Martin (für die Schichtentrennung)."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"italic"}],"text":"Building Microservices"},{"type":"text","text":" von Sam Newman (für das Verständnis von Slices und Bounded Contexts)."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"link","attrs":{"href":"https://martinfowler.com/bliki/BoundedContext.html","target":"_blank","rel":"noopener","class":"ng-star-inserted"}}],"text":"Martinfowler.com zu Bounded Contexts"},{"type":"text","text":" – Die Referenz für strukturelles Design."}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Ist ein spezifischer dieser Ansätze für ein aktuelles Architektur-Projekt besonders relevant, oder geht es primär um die methodische Übertragung auf die Steuerung von LLM-Agenten?"}]}]}},"parentId":"page:4HXlX8UVh4_VSuHOODuqS","index":"a1HH2fTV","typeName":"shape"},{"x":2029.044230365892,"y":40,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:MTdUFRjLr49TLd_3c2pFV","type":"text","props":{"color":"black","size":"m","w":1593.0765072448403,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Das Zerlegen einer Architektur in unabhängige, testbare Arbeitspakete (Phase 3 Ihres Diagramms) ist der kritische Punkt, an dem \"Intent\" in \"Implementation\" übergeht. Wenn Sie KI-gestütztes Engineering (AI-First) nutzen, dient die Theorie als "},{"type":"text","marks":[{"type":"bold"}],"text":"Leitplanke für den Agenten"},{"type":"text","text":", um Halluzinationen zu minimieren und modularen Code zu erzwingen."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Hier sind 20 Konzepte, übertragen auf den "},{"type":"text","marks":[{"type":"bold"}],"text":"Agentic Engineering Workflow"},{"type":"text","text":":"}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Strategische Empfehlung für Phase 3:"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Um diese Konzepte in Ihrem Workflow (vom "},{"type":"text","marks":[{"type":"bold"}],"text":"Design"},{"type":"text","text":" zum "},{"type":"text","marks":[{"type":"bold"}],"text":"Task"},{"type":"text","text":") zu verankern, sollten Sie die "},{"type":"text","marks":[{"type":"bold"}],"text":"\"Definition of Ready\" (DoR)"},{"type":"text","text":" für Ihre Tasks so definieren, dass der Agent gezwungen ist, gegen "},{"type":"text","marks":[{"type":"bold"}],"text":"Konzepte 1, 2 und 7"},{"type":"text","text":" zu validieren."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Ein Task ist erst \"Ready for Execute\", wenn:"}]},{"type":"orderedList","attrs":{"dir":"auto","start":1,"type":null},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Der "},{"type":"text","marks":[{"type":"bold"}],"text":"Bounded Context"},{"type":"text","text":" klar definiert ist (kein Zugriff auf fremde Module)."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Ein "},{"type":"text","marks":[{"type":"bold"}],"text":"Vertikaler Slice"},{"type":"text","text":" vorliegt (ein messbarer Mehrwert)."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Die "},{"type":"text","marks":[{"type":"bold"}],"text":"Interface-Definition"},{"type":"text","text":" (Port) vom menschlichen Lead-Dev abgenommen wurde."}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Dies stellt sicher, dass der Coding-Agent nicht nur \"Code schreibt\", sondern die geplante Architektur in stabilen, isolierten Einheiten materialisiert."}]}]}},"parentId":"page:4HXlX8UVh4_VSuHOODuqS","index":"a2yU1jXl","typeName":"shape"},{"id":"asset:-1162206423","type":"image","typeName":"asset","props":{"name":"Screenshot 2026-05-03 21.54.19.png","src":"data:image/png;base64,","w":1307,"h":633,"fileSize":166148,"mimeType":"image/png","isAnimated":false},"meta":{"fileId":"KZosCqiFq3mUJgzJ2ERK-"}},{"x":2029.044230365892,"y":598.1004578913916,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:bN4sKeI9g65knruLeGNNZ","type":"image","props":{"w":1988.2168995644977,"h":962.9237164684981,"assetId":"asset:-1162206423","playing":true,"url":"","crop":null,"flipX":false,"flipY":false,"altText":""},"parentId":"page:4HXlX8UVh4_VSuHOODuqS","index":"a3UseMxG","typeName":"shape"},{"meta":{},"id":"page:page","name":"Workflow Description","index":"a1","typeName":"page"},{"name":"","color":"#FF802B","imageUrl":"","meta":{},"id":"user:Q8xOMCp6GyWi28Tqu0W_g","typeName":"user"},{"name":"","color":"#55B467","imageUrl":"","meta":{},"id":"user:mxQqoZbEI_L7C9pessnTG","typeName":"user"},{"name":"","color":"#02B1CC","imageUrl":"","meta":{},"id":"user:lsKzaqN7FW5TaXdMOsXp2","typeName":"user"},{"name":"","color":"#EC5E41","imageUrl":"","meta":{},"id":"user:hT8CiaJx3cRMfKqmbRJmw","typeName":"user"},{"name":"","color":"#BD54C6","imageUrl":"","meta":{},"id":"user:cCypiDg5m3gFF5Qbxa87l","typeName":"user"},{"name":"","color":"#F04F88","imageUrl":"","meta":{},"id":"user:NFhaJ6D9piCU0xsvHwT80","typeName":"user"},{"name":"","color":"#9D5