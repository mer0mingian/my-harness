{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "version", "description", "commands"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "templates": {
      "type": "object",
      "properties": {
        "directory": {
          "type": "string"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "schema": {
          "type": "string"
        }
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "install": {
          "type": "string"
        }
      }
    }
  }
}
