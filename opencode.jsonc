{
    "$schema": "https://opencode.ai/config.json",
    // Set this as additional information for all agents.
    "instructions": [
        "README.md", 
        // "docs/README.md", 
        // TODO: Add architecture infos here from deepwiki!
    ],
    "plugin": [
        // TDD-workflow + addtional hooks
        "github:mer0mingian/opencode-froggy@latest", 
        //
        // Protect Env Variables
        "envsitter-guard@latest",
        //
        // Subtask-System
        // Installation: npm install -g @spoons-and-mirrors/subtask2
        "github:spoons-and-mirrors/subtask2#debug",
        //
        // Skill Evolution (mer0mingian fork - learns from skill usage)
        // Installation: opencode plugin opencode-skill-evolution@latest --global
        // "github:mer0mingian/opencode-skill-evolution",
        //
        // OpenCode-Hooks (mer0mingian fork - YAML hooks)
        // Installation: bun add "https://github.com/mer0mingian/OpenCode-Hooks.git"
        //
        // OpenCode Ensemble (mer0mingian fork - parallel agents)
        // Installation: npm install -g @hueyexe/opencode-ensemble
        // "github:mer0mingian/opencode-ensemble",
        //
        // OpenCode Plugin OpenSpec (mer0mingian fork - dedicated architect)
        // Installation: npm install -g opencode-plugin-openspec
        "github:mer0mingian/opencode-plugin-openspec",
        //
        // Background Agents (mer0mingian fork - delegate tool)
        // Installation: bun add "https://github.com/mer0mingian/opencode-background-agents.git"
        //
        // Agent Team (JsonLee12138 - go install)
        // Installation: go install github.com/JsonLee12138/agent-team@latest
        // Note: Not a plugin, requires separate CLI setup
    ],
/*  
    // Only needed if Conductor plugin active
    "agent": {
        "conductor": {
        "model": "google/gemini-flash-latest"
        }
    },
*/    
    "username": "Daniel",
    "mcp": {
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "CONTEXT7_API_KEY"
            ],
            "enabled": false,
            "environment": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "timeout": 20000
        },
        "tavily": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "tavily-mcp"
            ],
            "enabled": true,
            "environment": {
                "TAVILY_API_KEY": "{env:TAVILY_API_KEY}",
                "DEFAULT_PARAMETERS": "{\"include_images\": false, \"max_results\": 7}"
            },
            "timeout": 10000
        },
        "sequential-thinking": {
            "type": "local",
            "command": [
                "docker",
                "run",
                "--rm",
                "-i",
                "mcp/sequentialthinking"
            ],
            "enabled": true,
            "timeout": 20000
        },
        "exa-search": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "exa-mcp-server"
            ],
            "enabled": false,
            "environment": {
                "EXA_API_KEY": "{env:EXA_API_KEY}"
            },
            "timeout": 10000
        },
    },
    "tools": {
        "context7_*": false,
        "tavily_*": true,
        "sequential-thinking_*": true
    }
}
